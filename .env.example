# Sepolia RPC used by the optional CLI deploy and read-only smoke scripts.
# A real endpoint may embed an API token; keep it in ignored `.env` files and
# export it before running npm scripts (the scripts do not auto-load this file).
SEPOLIA_RPC_URL=https://your-sepolia-rpc.example

# Optional CLI deployment only. Prefer a disposable Sepolia key and never
# paste a seed phrase or commit a real value. MetaMask/Remix deployment does
# not use this variable.
DEPLOYER_PRIVATE_KEY=0xYOUR_64_HEX_TESTNET_PRIVATE_KEY

# Required for a release browser bundle and the read-only smoke script.
CIPHERGATE_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CIPHERGATE_ADDRESS
